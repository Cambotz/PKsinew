########################################
# SINEW – Git Ignore
########################################
# Override parent ignore
!*
# --- ROMs (never commit) ---

# Ignore all files in roms except the README
dist/roms/*
!dist/roms/README.txt


# --- Runtime / generated data ---
cache/
temp/
tmp/
system/

generated/
backups/
lib/
exports/
include/
scripts/
dist/data/sprites/gen3/normal/**
!dist/data/sprites/gen3/normal/egg.png
dist/data/sprites/gen3/shiny/*
dist/data/sprites/gen8
dist/data/sprites/ribbons
dist/data/sprites/items/master-ball.png
dist/data/sprites/items/poke-ball.png
dist/data/achievements/rewards/backup
dist/data/achievements_progress.json
dist/data/achievements/rewards/achievements_delivered.json
dist/data/achievements/rewards/echo_delivered.json
dist/data/sprite_pack_selection.json
dist/data/sprite_pack_preferences.json
dist/data/sprites/packs
src/sinew_settings.json
!dist/data/sounds/music/SinewMenu.mp3
dist/data/sprites/title/backup
dist/logs/
dist/saves/
dist/PKsinew*
sinew.log
sinew.log.1
# --- Build / packaged output ---
build/
out/

# --- Python ---
__pycache__/
venv/
*.pyc
*.pyo

# --- Node / tooling (if used) ---
node_modules/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors ---
.vscode/
.idea/
*.swp
sinew_settings.json
/.trunk
